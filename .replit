modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
EXPO_PUBLIC_GOOGLE_API_KEY = "AIzaSyDBJeuq01OQvMI3y65on6pe5ZL2P72yZeg"
GOOGLE_API_KEY = "AIzaSyDBJeuq01OQvMI3y65on6pe5ZL2P72yZeg"
