{
  "expo": {
    "name": "QuizBox",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "backgroundColor": "#FFFFFF",
      "package": "com.quizbox.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "QuizBox uses your photos to attach a screenshot to admin posts.",
          "cameraPermission": "QuizBox uses your camera to attach a photo to admin posts."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
